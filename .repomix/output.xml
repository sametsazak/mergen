    var fixRequiresAdmin: Bool {
        if Vulnerability.userFixes[cisID]  != nil { return false }
        if Vulnerability.adminFixes[cisID] != nil { return true }
        if Vulnerability.docIDAdminFixes[docID] != nil { return true }
        return false
    }

