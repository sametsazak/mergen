            .padding(.vertical, 4)
            .background(style == .filled ? color.opacity(0.13) : Color.primary.opacity(0.06))
            .cornerRadius(20)
            .overlay(
                RoundedRectangle(cornerRadius: 20)
                    .stroke(style == .outlined ? Color.secondary.opacity(0.25) : Color.clear, lineWidth: 1)
            )
    }
}
