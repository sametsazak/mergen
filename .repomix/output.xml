			// date +%s and time.Now() should agree within a few seconds locally
			if trim(out) == "" {
				return Result{StatusWarn, "Could not parse system time"}
			}
			return Result{StatusPass, "System time is within acceptable limits (epoch: " + trim(out) + ")"}
		},
	))
